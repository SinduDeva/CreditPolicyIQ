# Credit Policy Automation Tool - Configuration

# ============================================================================
# LLM PROVIDER CONFIGURATION
# ============================================================================

# Choose your LLM provider: anthropic, openai, or mock
# - anthropic: Anthropic Claude API (recommended)
# - openai: OpenAI GPT API (requires openai package)
# - mock: Mock provider (testing only, no API needed)
LLM_PROVIDER=anthropic

# Generic LLM API key (used by all providers)
# For Anthropic: https://console.anthropic.com/
# For OpenAI: https://platform.openai.com/account/api-keys
LLM_API_KEY=your-llm-api-key-here

# For backward compatibility, also support provider-specific keys
# Anthropic API key (alternative to LLM_API_KEY)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================================================
# FILE PATHS
# ============================================================================

# Path to the master credit policy DOCX file
MASTER_DOCX_PATH=data/master_policy.docx

# Path to the Excel file with policy changes
EXCEL_PATH=data/policy_changes.xlsx

# ============================================================================
# LLM MODEL CONFIGURATION
# ============================================================================

# Model name based on provider:
# - Anthropic: claude-3-5-sonnet-20241022 (recommended), claude-3-opus-20240229
# - OpenAI: gpt-4-turbo (recommended), gpt-4, gpt-3.5-turbo
LLM_MODEL=claude-3-5-sonnet-20241022

# Maximum tokens for LLM responses (affects response length and cost)
LLM_MAX_TOKENS=1000

# ============================================================================
# API CONFIGURATION
# ============================================================================

# FastAPI host and port
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit host and port
STREAMLIT_HOST=0.0.0.0
STREAMLIT_PORT=8501

# Base URL for API (used by Streamlit dashboard)
API_BASE_URL=http://localhost:8000/api

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================

# Maximum file size for uploads (in bytes, default 10MB)
MAX_UPLOAD_SIZE=10485760

# Allowed file extensions
ALLOWED_EXTENSIONS=xlsx,docx

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/app.log

# ============================================================================
# DATABASE CONFIGURATION (Optional for future expansion)
# ============================================================================

# Database URL for storing change history
# DATABASE_URL=postgresql://user:password@localhost/creditpolicy

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

# Cache directory for LLM responses
CACHE_DIR=data/cache

# Cache TTL in seconds (default: 86400 = 24 hours)
CACHE_TTL=86400

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application environment: development, staging, production
ENVIRONMENT=development

# Debug mode (set to false in production)
DEBUG=true

# ============================================================================
# EXTERNAL SERVICES (Optional)
# ============================================================================

# Email configuration for notifications
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Slack webhook for notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# SECURITY (For Production)
# ============================================================================

# JWT secret key for authentication (change in production)
# JWT_SECRET_KEY=your-secret-key-change-in-production

# CORS allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8501
